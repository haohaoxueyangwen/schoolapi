# SHTUClaudeProxy 环境变量配置模板
# 复制为 .env 并填入真实值

OPENAI_API_KEY="your-api-key-here"
OPENAI_BASE_URL="https://your-upstream-api.example.com/api/v1"

BIG_MODEL="GPT-5.5"
MIDDLE_MODEL="GPT-5.5"
SMALL_MODEL="GPT-5.5"

HOST="127.0.0.1"
PORT="8082"
LOG_LEVEL="INFO"

MAX_TOKENS_LIMIT="8192"
MIN_TOKENS_LIMIT="1024"
REQUEST_TIMEOUT="120"
MAX_RETRIES="2"
